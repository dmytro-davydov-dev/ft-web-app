# Copy to .env.local — never commit .env.local to git
# Values from Firebase console → Project settings → Your apps → flowterra-dev

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=flowterra-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=flowterra-dev
VITE_FIREBASE_STORAGE_BUCKET=flowterra-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Leave empty — Vite dev server proxies /api/* to API_PROXY_TARGET (no CORS).
# Set to the Cloud Run URL only for prod builds where there is no dev proxy.
VITE_API_BASE_URL=

# Cloud Run service URL for ft-api (no trailing slash) — server-side only.
# Used by vite.config.ts to forward /api/* requests during local dev.
# Get from: gcloud run services describe ft-api --region europe-west1 --format "value(status.url)"
# Never bundled into the browser build (no VITE_ prefix).
API_PROXY_TARGET=
